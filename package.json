    "tunnel": "cloudflared tunnel --url http://localhost:3000"
  },
  "dependencies": {
    "express": "^4.21.0",
    "express-session": "^1.18.0",
    "socket.io": "^4.7.0",
    "multer": "^1.4.5-lts.1"
  }
}
