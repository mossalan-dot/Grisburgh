{
  "name": "grisburgh",
  "version": "1.0.0",
  "description": "Grisburgh D&D Campaign Manager",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "test": "node --test --test-concurrency=1 'tests/*.test.js'",
